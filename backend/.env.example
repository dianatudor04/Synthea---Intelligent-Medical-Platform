# ─── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database (PostgreSQL) ────────────────────────────────
DATABASE_URL="postgresql://synthea_user:synthea_pass@localhost:5432/synthea_db"

# ─── JWT Authentication ───────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Frontend URL (CORS) ──────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── AI Services ─────────────────────────────────────────
# OpenAI API (for chatbot + clinical decision support)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo

# ─── Payment (Stripe) ────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret-here

# ─── File Storage ────────────────────────────────────────
# Uploads directory (for OCR documents)
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=20

# ─── OCR Service ─────────────────────────────────────────
# Option A: Local Tesseract.js (no key needed)
OCR_PROVIDER=tesseract
# Option B: Google Cloud Vision
# GCP_PROJECT_ID=your-gcp-project-id
# GCP_KEY_FILE=path/to/service-account.json
# Option C: Azure Computer Vision
# AZURE_VISION_KEY=your-azure-key
# AZURE_VISION_ENDPOINT=https://your-endpoint.cognitiveservices.azure.com

# ─── Logging ──────────────────────────────────────────────
LOG_LEVEL=info

# ─── Redis (optional — for token blacklist / caching) ────
# REDIS_URL=redis://localhost:6379
